    "@tanstack/react-router": "^1.170.18",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.26.1",
