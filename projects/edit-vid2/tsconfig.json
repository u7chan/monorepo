{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["node"],
    "paths": {
      "#/*": ["./src/*"]
    }
  },
  "exclude": ["node_modules", "tests/e2e"]
}
