{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:mock": "USE_MOCK_DATA=true bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "start:mock": "USE_MOCK_DATA=true NODE_ENV=production bun src/index.ts",
    "lint": "tsc --noEmit && oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.53.0",
    "typescript": "^5.9.3"
  }
}
