{
  "name": "browser-auto",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server/bun-server.ts",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "bun run lint && bun run format:check"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
